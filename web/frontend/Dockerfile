FROM node:22.22.2-bookworm AS build

WORKDIR /app

ARG VITE_TILES_URL
ARG VITE_SOURCE_MAX_ZOOM
ARG VITE_BASE_ZOOM_TRACK
ARG VITE_BASE_ZOOM_ALBUM
ARG VITE_BASE_ZOOM_ARTIST
ARG VITE_BASE_ZOOM_LABEL

ENV VITE_TILES_URL=$VITE_TILES_URL
ENV VITE_SOURCE_MAX_ZOOM=$VITE_SOURCE_MAX_ZOOM
ENV VITE_BASE_ZOOM_TRACK=$VITE_BASE_ZOOM_TRACK
ENV VITE_BASE_ZOOM_ALBUM=$VITE_BASE_ZOOM_ALBUM
ENV VITE_BASE_ZOOM_ARTIST=$VITE_BASE_ZOOM_ARTIST
ENV VITE_BASE_ZOOM_LABEL=$VITE_BASE_ZOOM_LABEL

COPY package.json package-lock.json ./
RUN npm ci

COPY . .
RUN npm run build

FROM nginx:1.27-alpine

COPY nginx.prod.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html

EXPOSE 80 443
