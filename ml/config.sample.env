# INPUTS.
export T2M_PLAYLIST_DB=
export T2M_TRACKS_DB=

# SECRET KEYS.
export LAMBDA_API_KEY=

# PARAMETERS.
# minimum number of tracks in training dataset
export T2M_ARTIST_MINTRACK=10
export T2M_ALBUM_MINTRACK=5
export T2M_LABEL_MINTRACK=100

# OUTPUTS.
# all scripts outputs are saved to the $T2M_OUTPUT_DIR unless specified otherwise.
export T2M_OUTPUT_DIR=outs/
export T2M_EMBEDDING_DIR=$T2M_OUTPUT_DIR/
export T2M_TRAINING_VOCAB=$T2M_OUTPUT_DIR/training_vocab.parquet
export T2M_LOOKUP_TRACK=$T2M_OUTPUT_DIR/lookup_track.parquet
export T2M_LOOKUP_ARTIST=$T2M_OUTPUT_DIR/lookup_artist.parquet
export T2M_LOOKUP_ALBUM=$T2M_OUTPUT_DIR/lookup_album.parquet
export T2M_LOOKUP_LABEL=$T2M_OUTPUT_DIR/lookup_label.parquet
