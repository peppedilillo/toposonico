export T2M_ROOT=

export T2M_PLAYLIST_DB=
export T2M_TRACKS_DB=

export T2M_MODEL_DIR=$T2M_ROOT/outs/models/
export T2M_EMBEDDING_DIR=$T2M_ROOT/outs/
export T2M_GEO_DIR=$T2M_ROOT/outs/geo/
export T2M_LOOKUP_DIR=$T2M_ROOT/outs/
export T2M_KNN_DIR=$T2M_ROOT/outs/knn
export T2M_DB=$T2M_ROOT/outs/track2map.db

export T2M_EMBEDDING=$T2M_EMBEDDING_DIR/track_embeddings.parquet
export T2M_TRACK_COUNT=$T2M_ROOT/outs/track_playlist_counts.parquet
export T2M_TRAINING_VOCAB=$T2M_ROOT/outs/training_vocab.parquet
export T2M_TRACK_LOOKUP=$T2M_LOOKUP_DIR/track_lookup.parquet

# All four UMAP parquets must come from the same UMAP fit.
# Mixing parquets from different fits produces incompatible geo coordinates.
export T2M_UMAP_DIR=$T2M_ROOT/outs/umap
export T2M_TRACK_UMAP=$T2M_UMAP_DIR/umap_track_2d_nn150_md0d01_cosine.parquet
export T2M_ALBUM_UMAP=$T2M_UMAP_DIR/umap_album_2d_nn150_md0d01_cosine.parquet
export T2M_ARTIST_UMAP=$T2M_UMAP_DIR/umap_artist_2d_nn150_md0d01_cosine.parquet
export T2M_LABEL_UMAP=$T2M_UMAP_DIR/umap_label_2d_nn150_md0d01_cosine.parquet
